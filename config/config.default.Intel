# check if necessary variables are correctly defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

FC      = f95i
CPP     = /lib/cpp -C -traditional

ifdef SOLPS_DEBUG
FFLAGS  = -g -O -C
else
FFLAGS  = -O3 -tpp7
endif

DBLPAD  = -Ad

COMPILE = ${FC} -c ${FFLAGS}

LDLIBS  = ${LD_MSCL}
LDFLAGS = ${LD_NCARG}
LDEXTRA =

