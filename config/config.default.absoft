# check if necessary variables are correctly defined
ifndef LD_MSCL
$(error LD_MSCL not defined)
endif
ifndef LD_NCARG
$(error LD_NCARG not defined)
endif

FC		= f95
CPP		= /lib/cpp -traditional -DREADOPT

ifdef SOLPS_DEBUG
FFLAGS		= -g -C -YEXT_NAMES=LCS -YEXT_SFX='_' -YCOM_NAMES=LCS -YCOM_SFX='_'
else
FFLAGS		= -O -YEXT_NAMES=LCS -YEXT_SFX='_' -YCOM_NAMES=LCS -YCOM_SFX='_'
endif

DBLPAD		= -N113 -i4

COMPILE 	= ${FC} -c ${FFLAGS}

LDLIBS		= ${LD_MSCL} ${LD_NCARG}
LDFLAGS 	=  
LDEXTRA 	= 
