# check if necessary variables are correctly defined
GLI_HOME ?= ${EBROOTGLI}
LD_MSCL  ?= $(shell pkg-config mscl --libs)
ifdef NCARG_ROOT
LD_NCARG ?= -L$(NCARG_ROOT)/lib -lncarg -lncarg_gks -lncarg_c -lX11 -lXext $(shell pkg-config cairo --libs) -lfontconfig -lfreetype -lpng -lz -lpthread -lXrender -lbz2 -ldl
endif

CPP       = /lib/cpp -traditional

ifdef SOLPS_DEBUG
FFLAGS    = -gdwarf-2 -fbacktrace
endif

DBLPAD    =

