# check if necessary variables are correctly defined
LD_MSCL  ?= -L/pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/mscl -lmscl
LD_NCARG ?= -L/pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/NCARG/lib -lncarg -lncarg_gks -lncarg_c -L/usr/X11R6/lib64 -lX11 -lxcb

FC      = g95
CPP     = /lib/cpp -traditional -ffreestanding

FFLAGS  = -ffree-line-length-huge -fno-second-underscore -fmod=${OBJDIR}/
ifdef SOLPS_DEBUG
FFLAGS += -g -C -fbounds-check -ftrace=full -Wall -Wno=unused-vars
LDFLAGS = -Wall
else
FFLAGS += -O
endif

ifeq ($(shell `pkg-config --exists fundamental-constants`; echo $$?),0)
B2INCLUDE += `pkg-config fundamental-constants --cflags`
endif

DBLPAD  = -r8

COMPILE = ${FC} -c ${FFLAGS} ${FFLAGSEXTRA}
MOD     = mod

LDLIBS  = ${LD_MSCL} ${LD_NCARG} ${LD_NAG}
LDFLAGS = 
LDEXTRA = ${LD_UAL}

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

