# check if necessary variables are correctly defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

ifndef SOLPS_CPP
DEFINES  += -DNAGFOR
endif

FC        = nagfor
CPP       = /lib/cpp -traditional

ifdef SOLPS_DEBUG
FFLAGS    = -g -C
else
FFLAGS    = -O
endif

DBLPAD    = -r8 -i4

COMPILE   = ${FC} -c ${FFLAGS}

LDLIBS    = ${LD_MSCL}
LDFLAGS   = ${LD_NCARG}
LDEXTRA   =

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

