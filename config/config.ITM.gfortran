# check if necessary variables are correctly defined
NCARG_ROOT ?= ${EBROOTNCL}
MSCL_ROOT ?= ${EBROOTMSCL}
GLI_HOME ?= ${EBROOTGLI}
LD_NCARG ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -lm -lX11 -lXext $(shell pkg-config cairo --libs) -lfontconfig -lfreetype -lpthread -lXrender
LD_MSCL ?= $(shell pkg-config mscl --libs)

CPP     = /lib/cpp -traditional

ifdef SOLPS_DEBUG
FFLAGS  = -fbacktrace
endif

DBLPAD  =

