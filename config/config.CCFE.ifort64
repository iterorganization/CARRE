# check if necessary variables are correctly defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

FC     ?= ifort
CPP     = /lib/cpp -traditional -ffreestanding

FFLAGS  = -module ${OBJDIR}
ifdef SOLPS_DEBUG
FFLAGS += -warn all -check noarg_temp_created  -warn notruncated_source -warn nounused  -p -gen-interfaces -warn interfaces
LDFLAGS =
endif

