# check if necessary variables are correctly defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif
ifndef LD_NCARG
  $(error LD_NCARG not defined)
endif

FC      = ftn
CPP     = /lib/cpp -traditional

FFLAGS  = -e0 -ez -ef
ifdef SOLPS_DEBUG
FFLAGS += -O0 -hfp0 -g -G0 -K trap=divz -K trap=fp -Rb
else
FFLAGS += -O3 -hfp3
endif

DBLPAD  =

COMPILE = ${FC} -c ${FFLAGS}

LDLIBS  = ${LD_MSCL} ${LD_NCARG}
LDFLAGS =
LDEXTRA =

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

