FC		= /opt/Fujitsu/bin/f90
FC		= f95f
CPP		= /lib/cpp -C -traditional

ifdef SOLPS_DEBUG
FFLAGS		= -g -Am -X9 -Hasu
else
FFLAGS		= -O3 -Am -X9 -Kfast,eval -x-
endif

DBLPAD		= -Ad 

COMPILE 	= ${FC} -c ${FFLAGS}

LDLIBS		= -L${SOLPS_LIB}
LDFLAGS 	= ${NCARG} -lmscl # ${NCARG_ROOT}/BD/*.o 
LDEXTRA 	= 
