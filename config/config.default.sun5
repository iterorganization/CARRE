#  VERSION : 18.03.2015

# check if necessary variables are correctly defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

FC      = f90
CPP     = /usr/ccs/lib/cpp

ifdef SOLPS_DEBUG
FFLAGS  = -g -C 
else
FFLAGS  = -O
endif

DBLPAD  = -r8 -i4
DBLPAD  = -xtypemap=real:64,double:64,integer:32

COMPILE = ${FC} -c ${FFLAGS}

LDLIBS  = ${LD_MSCL}
LDFLAGS = ${LD_NCARG} -lsocket
LDEXTRA = -lf77compat

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:
