FC		= g95
CPP		= /lib/cpp -C -traditional

ifdef SOLPS_DEBUG
FFLAGS		= -g -C -fbounds-check -ftrace=full
else
FFLAGS		= -g -O
endif

DBLPAD		= -r8 

COMPILE 	= ${FC} -c ${FFLAGS}

LDLIBS		= -L${NCARG_ROOT}/lib -L${SOLPS_LIB}
LDFLAGS 	= -lncarg -lncarg_gks -lncarg_c -L/usr/X11R6/lib -lX11 -lm -lmscl
LDEXTRA 	= 
