ifndef LD_MSCL
  ifndef SOLPS_CPP
    $(error LD_MSCL not defined)
  else
    $(error LD_MSCL not defined. Run the install_dependencies script first)
  endif
endif

ifndef SOLPS_CPP
DEFINES  += -DPGF90
FFLAGS   += -Mnorpath
endif

FC        = pgf90

ifdef SOLPS_DEBUG
FFLAGS   += -g -C
else
FFLAGS   += -O
endif

DBLPAD    = -r8 -i4

COMPILE   = ${FC} -c ${FFLAGS}

LDLIBS    = ${LD_MSCL}
LDFLAGS   = ${LD_NCARG}
LDEXTRA   =

INCMOD   = -I

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:
