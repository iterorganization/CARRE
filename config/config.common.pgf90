ifndef SOLPS_CPP
DEFINES  += -DPGF90
FFLAGS   += -Mnorpath
endif

FC        = pgf90

ifdef SOLPS_DEBUG
FFLAGS   += -g -C
else
FFLAGS   += -O
endif

DBLPAD    = -r8 -i4

COMPILE   = ${FC} -c ${FFLAGS}

LDLIBS    = ${LD_MSCL}
LDFLAGS   = ${LD_NCARG}
LDEXTRA   =

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

