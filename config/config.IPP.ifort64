# check if necessary variables are correctly defined
NCARG_ROOT ?= /tokp/work/dpc/SOLPS-ITER/NCARG
MSCL_ROOT  ?= /tokp/work/dpc/SOLPS-ITER/mscl
LD_MSCL    ?= -L${MSCL_ROOT} -lmscl
LD_NCARG   ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -L/tokp/work/software/TOK_2019/software/cairo/1.16.0/lib -lcairo -L/tokp/work/software/TOK_2019/software/freetype/2.11.1/lib -lfreetype -L/usr/lib64 -lX11 -lm

FC      = ifort
CPP     = /lib/cpp -C -traditional -ffreestanding

MAKETAGS = etags -o

