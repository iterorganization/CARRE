FC		= f95
CPP		= /lib/cpp -traditional -DREADOPT

ifdef SOLPS_DEBUG
FFLAGS		= -g -C -YEXT_NAMES=LCS -YEXT_SFX='_' -YCOM_NAMES=LCS -YCOM_SFX='_'
else
FFLAGS		= -O -YEXT_NAMES=LCS -YEXT_SFX='_' -YCOM_NAMES=LCS -YCOM_SFX='_'
endif

DBLPAD		= -N113 -i4

COMPILE 	= ${FC} -c ${FFLAGS}

LDLIBS		= -L${SOLPS_LIB}
LDFLAGS 	= ${NCARG} -lmscl
LDEXTRA 	= 
