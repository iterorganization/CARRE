FC		= f95
CPP		= /lib/cpp -traditional -DREADOPT

ifdef SOLPS_DEBUG
FFLAGS		= -g -C -YEXT_NAMES=LCS -YEXT_SFX='_' -YCOM_NAMES=LCS -YCOM_SFX='_'
else
FFLAGS		= -O -YEXT_NAMES=LCS -YEXT_SFX='_' -YCOM_NAMES=LCS -YCOM_SFX='_'
endif

DBLPAD		= -N113 -i4

COMPILE 	= ${FC} -c ${FFLAGS}

LDLIBS		= -L$${NCARG_ROOT}/lib -L$(SOLPSTOP)/src/lib/$(OBJECTCODE)
LDFLAGS 	= -lncarg -lncarg_gks -lncarg_c -L/usr/X11R6/lib -lX11 -lm -lmscl
LDEXTRA 	= 
