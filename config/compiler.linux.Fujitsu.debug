FC		= /opt/Fujitsu/bin/f90
FC		= f95f
CPP		= /lib/cpp -C -traditional

ifdef SOLPS_DEBUG
FFLAGS		= -g -Am -X9 -Hasu
else
FFLAGS		= -O3 -Am -X9 -Kfast,eval -x-
endif

DBLPAD		= -Ad 

COMPILE 	= ${FC} -c ${FFLAGS}

LDLIBS		= -L$${NCARG_ROOT}/lib -L$(SOLPSTOP)/src/lib/$(OBJECTCODE)
LDFLAGS 	= -lncarg -lncarg_gks -lncarg_c -L/usr/X11R6/lib -lX11 -lm -lmscl # ${NCARG_ROOT}/BD/*.o 
LDEXTRA 	= 
