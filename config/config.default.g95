# check if necessary variables are correctly defined
ifndef LD_MSCL
  ifndef SOLPS_CPP
    $(error LD_MSCL not defined)
  else
    $(error LD_MSCL not defined. Run the install_dependencies script first.)
  endif
endif
ifndef LD_NCARG
  $(error LD_NCARG not defined)
endif

FC      = g95
CPP     = /lib/cpp -traditional

FFLAGS  = -ffree-line-length-huge -fno-second-underscore -fmod=${OBJDIR}/
ifdef SOLPS_DEBUG
FFLAGS += -g -C -fbounds-check -ftrace=full -Wall -Wno=unused-vars
LDFLAGS = -Wall
else
FFLAGS += -O
endif

ifeq ($(shell `pkg-config --exists fundamental-constants`; echo $$?),0)
B2INCLUDE += $(shell pkg-config fundamental-constants --cflags)
endif

DBLPAD  = -r8

COMPILE = ${FC} -c ${FFLAGS} ${FFLAGSEXTRA}
MOD     = mod

LDLIBS  = ${LD_MSCL} ${LD_NCARG} ${LD_NAG}
LDFLAGS =
LDEXTRA = ${LD_UAL}

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:
