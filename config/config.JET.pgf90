# check if necessary variables are correctly defined
LD_MSCL   ?= -L${MSCL_ROOT} -lmscl

ifndef SOLPS_CPP
DEFINES += -DPGF90
endif

FC      = pgf90
CPP     = /lib/cpp -traditional

ifdef SOLPS_DEBUG
FFLAGS  = -g -C
else
FFLAGS  = -O
endif

DBLPAD  = -r8 -i4

COMPILE = ${FC} -c ${FFLAGS}

LDLIBS  = ${LD_MSCL}
LDFLAGS = ${LD_NCARG}
LDEXTRA =

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

