# check if necessary variables are correctly defined
LD_MSCL   ?= -L${MSCL_ROOT} -lmscl
LD_NCARG  ?= 

DEFINES = 
ifndef SOLPS_CPP
DEFINES  += -DPGF90
endif

FC      = pgf90
CPP     = /lib/cpp -traditional -ffreestanding

ifdef SOLPS_DEBUG
FFLAGS  = -g -C 
else
FFLAGS  = -O
endif

DBLPAD  = -r8 -i4

COMPILE = ${FC} -c ${FFLAGS} -module ${OBJDIR}
MOD     = mod

LDLIBS  = ${LD_MSCL} ${LD_NCARG}
LDFLAGS = 
LDEXTRA = 

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

