# check if necessary variables are correctly defined
LD_MSCL   ?= -L${MSCL_ROOT} -lmscl
LD_NCARG  ?= 

DEFINES   = 

FC		    = pgf90
CPP		    = /lib/cpp -traditional

ifdef SOLPS_DEBUG
FFLAGS		= -g -C 
else
FFLAGS		= -O
endif

DBLPAD		= -r8 -i4

COMPILE 	= ${FC} -c ${FFLAGS}

LDLIBS		= ${LD_MSCL} ${LD_NCARG}
LDFLAGS 	= 
LDEXTRA 	= 

